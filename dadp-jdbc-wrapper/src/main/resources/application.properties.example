# DADP JDBC Wrapper 설정 예시

# JDBC URL (dadp: prefix + DB connection parameters only)
spring.datasource.url=jdbc:dadp:mysql://localhost:3306/mydb?useSSL=false&serverTimezone=UTC
spring.datasource.driver-class-name=com.dadp.jdbc.DadpJdbcDriver
spring.datasource.username=root
spring.datasource.password=password

# Wrapper storage is fixed by the first `dadp wrapper schema register` flow.
